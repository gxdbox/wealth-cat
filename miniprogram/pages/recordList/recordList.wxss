.container {
  padding: 30rpx;
  padding-bottom: 120rpx;
  background: #f5f5f5;
  min-height: 100vh;
}

/* 统计卡片 */
.statistics-card {
  background: linear-gradient(135deg, #07c160 0%, #10b981 100%);
  border-radius: 20rpx;
  padding: 40rpx 30rpx;
  display: flex;
  justify-content: space-between;
  margin-bottom: 30rpx;
  color: #fff;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
}

.stat-label {
  font-size: 24rpx;
  opacity: 0.9;
  margin-bottom: 10rpx;
}

.stat-amount {
  font-size: 36rpx;
  font-weight: bold;
}

.stat-amount.expense {
  color: #ffcccc;
}

.stat-amount.income {
  color: #fff;
}

.stat-divider {
  width: 1rpx;
  background: rgba(255,255,255,0.3);
  margin: 0 20rpx;
}

/* 账单列表 */
.record-list {
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
}

.record-item {
  display: flex;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.record-item:last-child {
  border-bottom: none;
}

.record-icon {
  font-size: 48rpx;
  margin-right: 20rpx;
}

.record-info {
  flex: 1;
}

.record-note {
  font-size: 32rpx;
  color: #333;
  margin-bottom: 8rpx;
}

.record-date {
  font-size: 24rpx;
  color: #999;
}

.record-amount {
  font-size: 32rpx;
  font-weight: bold;
}

.record-amount.expense {
  color: #f56c6c;
}

.record-amount.income {
  color: #07c160;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 100rpx 0;
}

.empty-icon {
  font-size: 100rpx;
  margin-bottom: 30rpx;
}

.empty-text {
  font-size: 32rpx;
  color: #999;
  margin-bottom: 30rpx;
}

.empty-btn {
  background: #07c160;
  color: #fff;
  padding: 20rpx 60rpx;
  border-radius: 50rpx;
}

/* 浮动按钮 */
.floating-btn {
  position: fixed;
  right: 40rpx;
  bottom: 100rpx;
  width: 100rpx;
  height: 100rpx;
  background: #07c160;
  color: #fff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 64rpx;
  box-shadow: 0 8rpx 20rpx rgba(7, 193, 96, 0.4);
}
