.container {
  padding: 20rpx;
}

.title {
  font-size: 40rpx;
  font-weight: bold;
  text-align: center;
  margin: 40rpx 0;
}

.section {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.1);
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  margin-bottom: 20rpx;
  color: #333;
}

.input-box {
  margin-bottom: 20rpx;
}

.input {
  border: 2rpx solid #ddd;
  border-radius: 8rpx;
  padding: 20rpx;
  font-size: 28rpx;
}

.btn {
  margin: 10rpx 0;
}

.result {
  margin-top: 20rpx;
  padding: 20rpx;
  background: #f0f9eb;
  border-radius: 8rpx;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.time {
  font-size: 24rpx;
  color: #999;
}

.todo-list {
  margin-top: 20rpx;
}

.todo-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx;
  border-bottom: 1rpx solid #eee;
}

.todo-done {
  text-decoration: line-through;
  color: #999;
}

.small-btn {
  font-size: 24rpx;
  padding: 10rpx 20rpx;
  margin-left: 10rpx;
}

.delete {
  background: #fee;
  color: #f56c6c;
}

.upload-image {
  width: 100%;
  margin-top: 20rpx;
  border-radius: 8rpx;
}
