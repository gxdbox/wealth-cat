.container {
  padding: 30rpx;
  background: #f5f5f5;
  min-height: 100vh;
}

/* 类型选择 */
.type-selector {
  display: flex;
  gap: 20rpx;
  margin-bottom: 40rpx;
}

.type-btn {
  flex: 1;
  padding: 24rpx;
  text-align: center;
  background: #fff;
  border-radius: 12rpx;
  font-size: 32rpx;
  font-weight: bold;
  color: #666;
}

.type-btn.active {
  background: #07c160;
  color: #fff;
}

/* 金额输入 */
.amount-section {
  background: #fff;
  padding: 60rpx 30rpx;
  border-radius: 16rpx;
  margin-bottom: 30rpx;
  display: flex;
  align-items: center;
}

.amount-label {
  font-size: 40rpx;
  color: #07c160;
  font-weight: bold;
  margin-right: 20rpx;
}

.amount-input {
  flex: 1;
  font-size: 64rpx;
  font-weight: bold;
  color: #333;
}

/* 表单区域 */
.input-section {
  background: #fff;
  padding: 30rpx;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
}

.input-label {
  display: block;
  font-size: 28rpx;
  color: #999;
  margin-bottom: 20rpx;
}

.input-box {
  font-size: 32rpx;
  padding: 20rpx;
  background: #f5f5f5;
  border-radius: 8rpx;
}

/* 分类网格 */
.category-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 20rpx;
}

.category-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
}

.category-item.active {
  background: #e8f5e9;
  border: 2rpx solid #07c160;
}

.category-icon {
  font-size: 40rpx;
  margin-bottom: 10rpx;
}

.category-name {
  font-size: 24rpx;
  color: #666;
}

/* 日期选择 */
.picker-box {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx;
  background: #f5f5f5;
  border-radius: 8rpx;
  font-size: 32rpx;
}

.arrow {
  color: #999;
}

/* 提醒开关 */
.switch-box {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.switch-text {
  font-size: 28rpx;
  color: #666;
}

/* 提交按钮 */
.submit-btn {
  margin-top: 40rpx;
  padding: 30rpx;
  background: #07c160;
  color: #fff;
  font-size: 32rpx;
  font-weight: bold;
  border-radius: 12rpx;
}
