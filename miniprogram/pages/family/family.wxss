.container {
  padding: 30rpx;
  background: #f5f5f5;
  min-height: 100vh;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 100rpx;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 30rpx;
}

.empty-text {
  font-size: 32rpx;
  color: #666;
  text-align: center;
  margin-bottom: 60rpx;
  line-height: 1.6;
}

.input-section {
  width: 100%;
  margin-bottom: 30rpx;
}

.input-box {
  width: 100%;
  padding: 24rpx 30rpx;
  background: #fff;
  border-radius: 12rpx;
  font-size: 30rpx;
}

.create-btn,
.join-btn {
  width: 100%;
  padding: 30rpx;
  background: #07c160;
  color: #fff;
  font-size: 32rpx;
  font-weight: bold;
  border-radius: 12rpx;
  margin-bottom: 30rpx;
}

.join-btn {
  background: #1890ff;
}

.divider {
  color: #999;
  margin: 30rpx 0;
}

/* 家庭卡片 */
.family-card {
  background: linear-gradient(135deg, #07c160 0%, #10b981 100%);
  border-radius: 20rpx;
  padding: 40rpx 30rpx;
  color: #fff;
  margin-bottom: 30rpx;
  text-align: center;
}

.family-name {
  font-size: 40rpx;
  font-weight: bold;
  margin-bottom: 10rpx;
}

.family-id,
.family-members {
  font-size: 26rpx;
  opacity: 0.9;
  margin-bottom: 6rpx;
}

.copy-btn {
  margin-top: 20rpx;
  background: rgba(255,255,255,0.2);
  color: #fff;
  font-size: 26rpx;
  padding: 16rpx 40rpx;
  border-radius: 50rpx;
}

/* 统计区域 */
.stats-section {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
}

.stats-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
}

.stat-card {
  background: #f5f5f5;
  border-radius: 12rpx;
  padding: 30rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-value {
  font-size: 36rpx;
  font-weight: bold;
  color: #07c160;
  margin-bottom: 10rpx;
}

.stat-label {
  font-size: 24rpx;
  color: #999;
}

/* 成员列表 */
.members-section {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
}

.member-item {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.member-item:last-child {
  border-bottom: none;
}

.member-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #07c160, #10b981);
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  font-weight: bold;
  margin-right: 20rpx;
}

.member-info {
  flex: 1;
}

.member-name {
  display: block;
  font-size: 32rpx;
  color: #333;
  margin-bottom: 6rpx;
}

.member-role {
  font-size: 24rpx;
  color: #999;
  padding: 4rpx 12rpx;
  background: #f5f5f5;
  border-radius: 50rpx;
}

.remove-btn {
  font-size: 26rpx;
  color: #f56c6c;
  padding: 10rpx 20rpx;
}

/* 账单列表 */
.records-section {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
}

.record-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.record-item:last-child {
  border-bottom: none;
}

.record-info {
  flex: 1;
}

.record-note {
  display: block;
  font-size: 30rpx;
  color: #333;
  margin-bottom: 6rpx;
}

.record-user {
  font-size: 24rpx;
  color: #999;
}

.record-amount {
  font-size: 32rpx;
  font-weight: bold;
}

.record-amount.expense {
  color: #f56c6c;
}

.record-amount.income {
  color: #07c160;
}

/* 退出区域 */
.leave-section {
  text-align: center;
  padding-bottom: 60rpx;
}

.leave-btn,
.dismiss-btn {
  background: #fff;
  color: #f56c6c;
  padding: 24rpx 60rpx;
  font-size: 28rpx;
  border-radius: 50rpx;
  border: 2rpx solid #f56c6c;
}

.dismiss-btn {
  color: #ff9800;
  border-color: #ff9800;
}
