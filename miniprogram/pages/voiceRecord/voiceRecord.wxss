.container {
  padding: 40rpx 30rpx;
  background: #f5f5f5;
  min-height: 100vh;
}

/* 语音区域 */
.voice-section {
  background: #fff;
  border-radius: 20rpx;
  padding: 60rpx 30rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 40rpx;
}

.voice-icon {
  font-size: 120rpx;
  margin-bottom: 30rpx;
}

.voice-status {
  font-size: 36rpx;
  color: #333;
  font-weight: bold;
  margin-bottom: 20rpx;
}

.voice-hint {
  font-size: 28rpx;
  color: #999;
  background: #f5f5f5;
  padding: 16rpx 30rpx;
  border-radius: 50rpx;
}

/* 录音按钮 */
.record-btn-box {
  display: flex;
  justify-content: center;
  margin-bottom: 40rpx;
}

.record-btn {
  width: 200rpx;
  height: 200rpx;
  border-radius: 50%;
  background: #fff;
  border: 4rpx solid #07c160;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 20rpx rgba(7, 193, 96, 0.2);
}

.record-btn.recording {
  background: #07c160;
  animation: pulse 1s infinite;
}

.btn-icon {
  font-size: 60rpx;
  margin-bottom: 10rpx;
}

.btn-text {
  font-size: 24rpx;
  color: #07c160;
}

.record-btn.recording .btn-text {
  color: #fff;
}

@keyframes pulse {
  0%, 100% {
    transform: scale(1);
  }
  50% {
    transform: scale(1.05);
  }
}

/* 识别结果 */
.result-section {
  background: #e8f5e9;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
}

.result-title {
  font-size: 28rpx;
  color: #07c160;
  font-weight: bold;
  margin-bottom: 16rpx;
}

.result-content {
  font-size: 30rpx;
  color: #333;
  line-height: 1.6;
}

/* 手动输入 */
.manual-section {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
}

.manual-title {
  display: block;
  font-size: 28rpx;
  color: #666;
  margin-bottom: 20rpx;
}

.manual-input {
  width: 100%;
  min-height: 200rpx;
  padding: 20rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
  font-size: 30rpx;
  margin-bottom: 20rpx;
}

.submit-btn {
  width: 100%;
  padding: 24rpx;
  background: #07c160;
  color: #fff;
  font-size: 32rpx;
  font-weight: bold;
  border-radius: 12rpx;
}

/* 加载遮罩 */
.loading-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.loading-content {
  background: #fff;
  border-radius: 20rpx;
  padding: 60rpx 80rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.loading-icon {
  font-size: 80rpx;
  margin-bottom: 30rpx;
  animation: bounce 1s infinite;
}

.loading-text {
  font-size: 32rpx;
  color: #333;
}

@keyframes bounce {
  0%, 100% {
    transform: translateY(0);
  }
  50% {
    transform: translateY(-20rpx);
  }
}
